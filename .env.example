# ================================================================
# AI Transcriber Bot - Configuration File
# ================================================================
# Скопируйте этот файл в .env и заполните своими значениями
# ================================================================

# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Администраторы бота (через запятую)
ADMIN_USERNAMES=your_username_here

# ================================================================
# Kafka
# ================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CLIENT_ID=ai-transcriber

# ================================================================
# PostgreSQL Database
# ================================================================
DB_NAME=ai_transcriber
DB_USER=bot
DB_PASSWORD=secret

# ================================================================
# Whisper (транскрибация голоса)
# ================================================================
WHISPER_MODEL=small  # tiny/base/small/medium/large
WHISPER_DEVICE=cpu  # cpu/cuda

# ================================================================
# TTS (синтез речи)
# ================================================================
TTS_LANGUAGE=ru  # ru/en/es/de/fr/it

# ================================================================
# OCR (распознавание текста)
# ================================================================
# GPU Type для OCR: cpu / nvidia / amd
OCR_GPU_TYPE=cpu

# ================================================================
# Image Generation (генерация изображений)
# ================================================================
SDXL_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
SD15_MODEL_ID=runwayml/stable-diffusion-v1-5
FLUX_MODEL_ID=black-forest-labs/FLUX.1-dev

# GPU Type: intel (default) / nvidia / amd
GPU_TYPE=intel

# ================================================================
# Безопасность и лимиты
# ================================================================
MAX_FILE_SIZE_MB=20
RATE_LIMIT_PER_MINUTE=10

# ================================================================
# Логирование
# ================================================================
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
