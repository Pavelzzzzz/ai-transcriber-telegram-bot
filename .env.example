# Токен Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Список администраторов бота (через запятую, без @)
# Пример: ADMIN_USERNAMES=admin1,admin2,superuser
ADMIN_USERNAMES=your_username_here

# Настройки Whisper (для производительности)
WHISPER_MODEL=tiny  # tiny/base/small/medium/large
WHISPER_DEVICE=cpu  # cpu/cuda

# Ограничения
MAX_FILE_SIZE_MB=20
RATE_LIMIT_PER_MINUTE=10

# Настройки базы данных (для продакшена)
# DATABASE_URL=postgresql://username:password@localhost/dbname

# Режим отладки
LOG_LEVEL=INFO
