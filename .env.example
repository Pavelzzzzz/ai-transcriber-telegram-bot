# Токен Telegram бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Список администраторов бота (через запятую, без @)
# Пример: ADMIN_USERNAMES=admin1,admin2,superuser
ADMIN_USERNAMES=your_username_here

# Настройки базы данных (для продакшена)
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Другие настройки могут быть добавлены по необходимости