# ================================================================
# AI Transcriber Bot - Configuration File
# ================================================================
# Скопируйте этот файл в .env и заполните своими значениями
# ================================================================

# Токен Telegram бота (ОБЯЗАТЕЛЬНО!)
# 1. Найдите @BotFather в Telegram
# 2. Отправьте команду /newbot
# 3. Следуйте инструкциям для создания бота
# 4. Скопируйте полученный токен сюда
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Имена администраторов бота (через запятую, без @)
# Пример: ADMIN_USERNAMES=admin1,admin2,superuser
# Ваши администраторы смогут использовать команды: /admin, /stats, /users, /logs
ADMIN_USERNAMES=your_username_here

# Настройки Whisper (для транскрибации голоса)
WHISPER_MODEL=tiny  # tiny/base/small/medium/large
# tiny - очень быстро, менее точно
# base - баланс скорости и качества
# small/medium/large - лучше качество, медленнее
WHISPER_DEVICE=cpu  # cpu/cuda
# cpu - для любого компьютера
# cuda - для NVIDIA GPU с поддержкой CUDA

# Ограничения и безопасность
MAX_FILE_SIZE_MB=20  # Максимальный размер файла в МБ
RATE_LIMIT_PER_MINUTE=10  # Ограничение запросов в минуту

# Настройки логирования
LOG_LEVEL=INFO  # DEBUG/INFO/WARNING/ERROR
# INFO - стандартные сообщения
# DEBUG - подробная отладочная информация
# WARNING - только предупреждения и ошибки

# Настройки Text-to-Speech (TTS)
TTS_LANGUAGE=ru  # Язык синтеза речи (ru/en/es/de/fr/it и др.)

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CLIENT_ID=ai-transcriber

# Stable Diffusion XL (Image Generation)
SDXL_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0

# Настройки базы данных (для продакшена)
# DATABASE_URL=postgresql://username:password@localhost/dbname

# Дополнительные переменные окружения
PYTHONUNBUFFERED=1  # Обязательно для корректного вывода логов
